# ================================
# NovaRAG Ollama Config
# ================================

# Ollama base URL (default — change if Ollama runs on another machine)
OLLAMA_HOST=http://localhost:11434

# Default model to use (must be pulled first via: ollama pull <model>)
# Popular options: llama3, llama3.1, mistral, gemma2, phi3, qwen2, deepseek-r1
OLLAMA_MODEL=llama3

# ngrok Auth Token (for public URL)
# Get from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=3E9lXVACiYzYw73HydL4Ohff8oA_5c64x2PEP1BqKPDdGTuyX

# Server port
PORT=8001
